{
    "model": {
        "default": "gemini-3-pro-preview",
        "thinking": "gemini-3-ultra-thinking",
        "parameters": {
            "temperature": 0.2,
            "topP": 0.95,
            "maxOutputTokens": 8192,
            "thinkingBudget": 4000
        }
    },
    "routing": {
        "strategy": "automatic",
        "rules": [
            {
                "pattern": "(architecture|schema|design)",
                "model": "gemini-3-ultra-thinking"
            },
            {
                "pattern": "(fix|debug|error)",
                "model": "gemini-3-pro-preview"
            }
        ]
    },
    "tools": {
        "approved": [
            "read_file",
            "list_dir",
            "grep_search",
            "run_command:npm run dev",
            "run_command:npm run type-check"
        ],
        "auto_approve": [
            "read_file",
            "list_dir"
        ]
    },
    "hooks": {
        "pre_write": [
            "scripts/validate_ddd.sh"
        ]
    },
    "plan_mode": "always"
}