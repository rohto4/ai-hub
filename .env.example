# Neon (PostgreSQL)
DATABASE_URL=
DATABASE_URL_UNPOOLED=
# Firebase (Admin SDK - service account JSON values)
FIREBASE_PROJECT_ID=ai-hub-d8fb9
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-fbsvc@ai-hub-d8fb9.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Firebase (Client SDK - web app settings)
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSy...
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id

# Gemini AI
GEMINI_API_KEY=
GEMINI_SUMMARY_MODEL=gemini-2.5-flash
OPENAI_API_KEY=
OPENAI_SUMMARY_MODEL=gpt-5-mini
ENRICH_SUMMARY_BATCH_SIZE=10
ENRICH_SUMMARY_BATCH_PAUSE_MS=0

# Web Push (generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# Internal API secret (for cron jobs)
CRON_SECRET=your-random-secret-here
